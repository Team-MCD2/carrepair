---
import BaseLayout from '../layouts/BaseLayout.astro';
import YouTubeLoop from '../components/YouTubeLoop.astro';
import { YOUTUBE } from '../data/videos';
---

<BaseLayout
  title="Nos Prestations — Mécanique, Carrosserie & Pneumatique | Car Repair Toulouse"
  description="Découvrez les prestations de Car Repair Toulouse : entretien mécanique, carrosserie, pneumatique et vente de véhicules."
  active="prestations"
  ogImage="https://www.car-repair.fr/assets/prestations.jpeg"
>
<!-- Subpage Hero -->
    <section class="subpage-hero subpage-hero--video">
        <div class="hero-video-wrap" aria-hidden="true">
            <YouTubeLoop videoId={YOUTUBE.hero} cover={true} class="hero-yt" />
        </div>
        <div class="container subpage-hero-content reveal-on-scroll">
            <ul class="breadcrumbs">
                <li><a href="/">Accueil</a></li>
                <li class="active">Prestations</li>
            </ul>
            <h1 class="subpage-title text-gradient">Nos Prestations</h1>
            <p class="subpage-desc">De l'entretien mécanique périodique aux travaux lourds de carrosserie ou à la recherche d'un nouveau véhicule, découvrez l'ensemble de notre offre.</p>
        </div>
    </section>

    <!-- Prestation Block 1: Mécanique -->
    <section id="mecanique" class="prestation-section">
        <div class="container">
            <div class="prestation-row">
                <div class="prestation-info">
                    <h2>Entretien &amp; Mécanique Générale</h2>
                    <p>Votre moteur est le cœur de votre véhicule. Notre équipe de mécaniciens expérimentés assure son entretien optimal et résout toutes les pannes mécaniques complexes avec des outils de diagnostic de pointe.</p>
                    <ul class="prestation-list">
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Vidange &amp; Révision complète
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Kit de Distribution
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Système de Freinage
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Remplacement Embrayage
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Diagnostic Électronique
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Batteries &amp; Alternateur
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Entretien Climatisation
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Suspensions &amp; Amortisseurs
                        </li>
                    </ul>
                    <a href="/contact/?service=mecanique" class="btn btn-primary">Demander un tarif</a>
                </div>
                <div class="prestation-media media-video">
                    <YouTubeLoop videoId={YOUTUBE.pourquoi} cover={true} title="Mécanique" />
                </div>
            </div>
        </div>
    </section>

    <!-- Prestation Block 2: Carrosserie -->
    <section id="carrosserie" class="prestation-section">
        <div class="container">
            <div class="prestation-row">
                <div class="prestation-media media-video">
                    <YouTubeLoop videoId={YOUTUBE.carrosserie} cover={true} title="Carrosserie" />
                </div>
                <div class="prestation-info">
                    <h2>Carrosserie &amp; Peinture</h2>
                    <p>Pour effacer les marques du temps ou suite à un accrochage, notre pôle carrosserie prend en charge la tôlerie et la peinture de votre véhicule. Nous réalisons des finitions impeccables respectant la teinte constructeur.</p>
                    <ul class="prestation-list">
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Débosselage sans peinture
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Remplacement d'éléments
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Peinture cabine de précision
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Rénovation plastiques
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Polissage &amp; Lustrage complet
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Rénovation optiques phares
                        </li>
                    </ul>
                    <a href="/contact/?service=carrosserie" class="btn btn-primary">Devis carrosserie</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Prestation Block 3: Pneumatique -->
    <section id="pneumatique" class="prestation-section">
        <div class="container">
            <div class="prestation-row">
                <div class="prestation-info">
                    <h2>Pneumatique &amp; Liaison au Sol</h2>
                    <p>Un pneu en bon état est indispensable pour une tenue de route sécurisante. Spécialistes pneumatiques, nous installons les plus grandes marques de pneus et réalisons les réglages géométriques indispensables.</p>
                    <ul class="prestation-list">
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Montage toutes marques
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Équilibrage de précision
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Contrôle parallélisme
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Contrôle usure et pression
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Réparation crevaison
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Pneus été / hiver / 4 saisons
                        </li>
                    </ul>
                    <a href="/contact/?service=pneumatique" class="btn btn-primary">Trouver mes pneus</a>
                </div>
                <div class="prestation-media">
                    <img src="/assets/vehicules.png" alt="Pneumatique" class="prestation-img" />
                </div>
            </div>
        </div>
    </section>

    <!-- Prestation Block 4: Vente/Achat -->
    <section id="vente-achat" class="prestation-section">
        <div class="container">
            <div class="prestation-row">
                <div class="prestation-media media-video">
                    <YouTubeLoop videoId={YOUTUBE.achat} cover={true} title="Achat véhicule" />
                </div>
                <div class="prestation-info">
                    <h2>Achat &amp; Vente de Véhicules</h2>
                    <p>Vous souhaitez changer de véhicule ? Nous disposons d'un catalogue de véhicules d'occasion rigoureusement inspectés, révisés et garantis. Nous estimons et rachetons également votre voiture actuelle en toute sérénité.</p>
                    <ul class="prestation-list">
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Conseils d'experts
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Estimation gratuite &amp; rapide
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Garantie mécanique incluse
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Fiabilité &amp; Historique clair
                        </li>
                        <li class="prestation-list-item">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Prise en charge des démarches
                        </li>
                    </ul>
                    <a href="/contact/?service=achat-vente" class="btn btn-primary">Estimer ma voiture</a>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="section-padding bg-noir-light">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Foire Aux Questions</h2>
                <p>Retrouvez les réponses aux questions les plus courantes posées à notre équipe commerciale et technique.</p>
            </div>
            
            <div class="faq-container">
                <!-- Item 1 -->
                <div class="faq-item">
                    <button class="faq-question">
                        Quels types de véhicules réparez-vous ?
                        <svg class="faq-icon-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="faq-answer">
                        <div class="faq-answer-content">
                            Nous sommes un réparateur multimarques : nous entretenons et réparons tous les types de véhicules légers et utilitaires, quel que soit le modèle ou le constructeur. De Peugeot à Mercedes, en passant par Audi ou Toyota, notre atelier est qualifié.
                        </div>
                    </div>
                </div>
                <!-- Item 2 -->
                <div class="faq-item">
                    <button class="faq-question">
                        Proposez-vous des devis gratuits ?
                        <svg class="faq-icon-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="faq-answer">
                        <div class="faq-answer-content">
                            Oui, nous établissons systématiquement un devis détaillé et totalement gratuit avant d'effectuer toute opération sur votre voiture. Pas de frais cachés, vous validez chaque étape.
                        </div>
                    </div>
                </div>
                <!-- Item 3 -->
                <div class="faq-item">
                    <button class="faq-question">
                        Quels sont vos horaires d'ouverture ?
                        <svg class="faq-icon-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="faq-answer">
                        <div class="faq-answer-content">
                            Le garage Car Repair à Toulouse vous accueille du lundi au vendredi de 9h00 à 18h00, et le samedi de 10h00 à 17h00. Nous sommes fermés le dimanche.
                        </div>
                    </div>
                </div>
                <!-- Item 4 -->
                <div class="faq-item">
                    <button class="faq-question">
                        Faites-vous le montage de pneumatiques ?
                        <svg class="faq-icon-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="faq-answer">
                        <div class="faq-answer-content">
                            Oui, nous assurons le montage rapide, l'équilibrage et le contrôle géométrique complet de vos pneumatiques. Vous pouvez commander vos pneus ou nous laisser choisir la meilleure marque pour votre budget.
                        </div>
                    </div>
                </div>
                <!-- Item 5 -->
                <div class="faq-item">
                    <button class="faq-question">
                        Proposez-vous un service de vente de véhicules ?
                        <svg class="faq-icon-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="faq-answer">
                        <div class="faq-answer-content">
                            Oui, nous proposons une sélection de véhicules d'occasion rigoureusement contrôlés et garantis à l'achat. De plus, nous vous proposons une estimation gratuite et le rachat de votre ancien véhicule en 24h.
                        </div>
                    </div>
                </div>
                <!-- Item 6 -->
                <div class="faq-item">
                    <button class="faq-question">
                        Comment prendre rendez-vous ?
                        <svg class="faq-icon-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="faq-answer">
                        <div class="faq-answer-content">
                            Vous pouvez prendre rendez-vous directement par téléphone au 05 62 83 74 29 ou 07 49 92 44 36. Il est également possible de nous envoyer un e-mail ou de remplir notre formulaire de contact en ligne.
                        </div>
                    </div>
                </div>
                <!-- Item 7 -->
                <div class="faq-item">
                    <button class="faq-question">
                        Êtes-vous agréé assurance ?
                        <svg class="faq-icon-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="faq-answer">
                        <div class="faq-answer-content">
                            Oui, nous collaborons avec de nombreuses compagnies d'assurance pour les travaux de carrosserie et de réparation mécanique suite à un accident. Nous facilitons vos démarches administratives.
                        </div>
                    </div>
                </div>
                <!-- Item 8 -->
                <div class="faq-item">
                    <button class="faq-question">
                        Où êtes-vous situés ?
                        <svg class="faq-icon-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="faq-answer">
                        <div class="faq-answer-content">
                            Notre garage est idéalement situé au 34 Rue Adolphe Coll, 31300 Toulouse, à proximité des boulevards et de la station de tramway, ce qui vous permet de laisser votre véhicule facilement.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Call To Action Banner -->
    <section class="cta-banner">
        <div class="container cta-container">
            <h2 class="cta-title">Besoin d'un devis immédiat ?</h2>
            <p class="cta-desc">Remplissez notre formulaire en ligne ou passez au garage directement pour faire estimer l'intervention nécessaire par un chef d'atelier.</p>
            <div class="cta-actions">
                <a href="tel:0562837429" class="phone-big">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                    05 62 83 74 29
                </a>
                <a href="/contact/" class="btn btn-primary">Faire ma demande en ligne</a>
            </div>
        </div>
    </section>

    <!-- Footer -->
</BaseLayout>

