---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCinematic from '../components/HeroCinematic.astro';
import VideoCard from '../components/VideoCard.astro';
import MediaVideo from '../components/MediaVideo.astro';
import { VIDEOS, POSTERS, showcaseVideos } from '../data/videos';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AutoRepair',
  name: 'Car Repair',
  image: 'https://www.car-repair.fr/assets/logo.png',
  url: 'https://www.car-repair.fr',
  telephone: ['+33562837429', '+33749924436'],
  email: 'info@car-repair.fr',
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '34 Rue Adolphe Coll',
    addressLocality: 'Toulouse',
    postalCode: '31300',
    addressCountry: 'FR',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 43.598285, longitude: 1.423026 },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '18:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Saturday',
      opens: '10:00',
      closes: '17:00',
    },
  ],
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.5', reviewCount: '500' },
};
---

<BaseLayout
  title="Car Repair — Garage Automobile Multimarques à Toulouse"
  description="Car Repair, votre garage automobile à Toulouse (31300). Mécanique toutes marques, carrosserie, peinture, pneumatique et vente de véhicules. Devis gratuit. ☎ 05 62 83 74 29."
  active="index"
  jsonLd={jsonLd}
>
  <HeroCinematic>
    <div class="hero-tagline reveal-item">Votre expert auto à Toulouse</div>
    <h1 class="hero-title text-gradient reveal-item">Entretien, Mécanique &amp; Carrosserie de Précision</h1>
    <p class="hero-desc reveal-item">
      CAR REPAIR prend soin de votre véhicule. Profitez d'une expertise multimarque de qualité, de tarifs compétitifs et de mécaniciens passionnés au cœur de Toulouse.
    </p>
    <div class="hero-buttons reveal-item">
      <a href="/contact.html" class="btn btn-primary">
        Prendre Rendez-vous
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
      <a href="/prestations.html" class="btn btn-secondary">Découvrir Prestations</a>
    </div>
  </HeroCinematic>

  <section class="trust-banner">
    <div class="container">
      <div class="trust-grid">
        <div class="trust-item reveal-on-scroll">
          <span class="trust-number" data-count="4.5" data-suffix="/5">4.5/5</span>
          <span class="trust-text">Note Google</span>
          <span class="trust-sub">Plus de 500 avis clients</span>
        </div>
        <div class="trust-item reveal-on-scroll" data-delay="100">
          <span class="trust-number" data-count="100" data-suffix="%">100%</span>
          <span class="trust-text">Multimarque</span>
          <span class="trust-sub">Diagnostic et pièces certifiées</span>
        </div>
        <div class="trust-item reveal-on-scroll" data-delay="200">
          <span class="trust-number" data-count="500" data-prefix="+">+500</span>
          <span class="trust-text">Véhicules Réparés</span>
          <span class="trust-sub">Par an avec passion</span>
        </div>
        <div class="trust-item reveal-on-scroll" data-delay="300">
          <span class="trust-number" data-count="2021">2021</span>
          <span class="trust-text">À votre service</span>
          <span class="trust-sub">Garage local toulousain</span>
        </div>
      </div>
    </div>
  </section>

  <section class="video-showcase section-padding">
    <div class="container">
      <div class="section-header reveal-on-scroll">
        <h2 class="section-title">L'atelier en action</h2>
        <p>Plongez dans l'univers de notre garage : diagnostic, mécanique de précision et passion automobile au quotidien.</p>
      </div>
      <div class="video-grid">
        {showcaseVideos.map((v, i) => (
          <VideoCard src={v.src} poster={v.poster} tag={v.tag} title={v.title} delay={i * 150} />
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container">
      <div class="section-header reveal-on-scroll">
        <h2 class="section-title">Nos Prestations Principales</h2>
        <p>Découvrez notre savoir-faire pour toutes les réparations, la maintenance ou l'entretien esthétique de votre automobile.</p>
      </div>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
          </div>
          <h3 class="service-title">Mécanique Générale</h3>
          <p>Vidange, révision, freinage, embrayage, kit de distribution. Nous intervenons sur l'ensemble de la motorisation et des organes mécaniques.</p>
          <a href="/prestations.html#mecanique" class="service-link">En savoir plus <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg></a>
        </div>
        <div class="service-card">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"></path><circle cx="7" cy="17" r="2"></circle><circle cx="17" cy="17" r="2"></circle></svg>
          </div>
          <h3 class="service-title">Carrosserie &amp; Peinture</h3>
          <p>Débosselage, traitement des rayures, peinture de précision et restauration plastique pour redonner à votre véhicule son aspect d'origine.</p>
          <a href="/prestations.html#carrosserie" class="service-link">En savoir plus <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg></a>
        </div>
        <div class="service-card">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="4"></circle><line x1="12" y1="2" x2="12" y2="4"></line><line x1="12" y1="20" x2="12" y2="22"></line><line x1="2" y1="12" x2="4" y2="12"></line><line x1="20" y1="12" x2="22" y2="12"></line></svg>
          </div>
          <h3 class="service-title">Pneumatique</h3>
          <p>Spécialistes du pneu. Montage rapide, équilibrage professionnel et contrôle géométrique pour assurer votre tenue de route et votre sécurité.</p>
          <a href="/prestations.html#pneumatique" class="service-link">En savoir plus <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg></a>
        </div>
      </div>
    </div>
  </section>

  <section class="why-section bg-noir-light section-padding">
    <div class="container why-container">
      <div class="why-grid">
        <div>
          <h2 class="section-title" style="text-align: left; display: block; margin-bottom: 2rem;">Pourquoi Choisir Notre Garage ?</h2>
          <div class="why-features">
            <div class="feature-item">
              <div class="feature-number">01</div>
              <div class="feature-content">
                <h3>Service de Haute Qualité</h3>
                <p>Nous n'utilisons que des pièces certifiées d'origine ou équivalentes. Nos diagnostics électroniques précis identifient les pannes exactes sans mauvaise surprise.</p>
              </div>
            </div>
            <div class="feature-item">
              <div class="feature-number">02</div>
              <div class="feature-content">
                <h3>Mécaniciens Expérimentés</h3>
                <p>Notre équipe possède une solide expérience technique multimarque. Qu'il s'agisse d'un moteur thermique classique ou d'équipements récents, nous maîtrisons chaque geste.</p>
              </div>
            </div>
            <div class="feature-item">
              <div class="feature-number">03</div>
              <div class="feature-content">
                <h3>Prix Transparents &amp; Imbattables</h3>
                <p>Un devis détaillé vous est présenté et expliqué avant toute réparation. Nous calculons au plus juste pour vous proposer un rapport qualité-prix sans équivalent sur Toulouse.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="why-image-wrapper reveal-on-scroll">
          <MediaVideo src={VIDEOS.mecanicien} poster={POSTERS.equipe} />
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container">
      <div class="section-header reveal-on-scroll">
        <h2 class="section-title">Ce que disent nos clients</h2>
        <p>La satisfaction de nos clients est notre plus belle récompense. Découvrez les derniers avis postés sur notre fiche d'établissement Google.</p>
      </div>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-header">
            <div class="review-author">
              <div class="author-avatar">J</div>
              <div class="author-info"><h4>Julien Martinez</h4><span>Il y a 2 semaines</span></div>
            </div>
            <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google" class="google-g" width="18" height="18" loading="lazy" />
          </div>
          <div class="review-stars">★ ★ ★ ★ ★</div>
          <p class="review-content">"Excellent accueil de l'équipe de Car Repair. Ils ont diagnostiqué un problème d'injecteur que d'autres garages n'avaient pas résolu. Facture très honnête et délais respectés."</p>
        </div>
        <div class="review-card">
          <div class="review-header">
            <div class="review-author">
              <div class="author-avatar">M</div>
              <div class="author-info"><h4>Marie Lassalle</h4><span>Il y a 1 mois</span></div>
            </div>
            <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google" class="google-g" width="18" height="18" loading="lazy" />
          </div>
          <div class="review-stars">★ ★ ★ ★ ★</div>
          <p class="review-content">"Je suis venue pour le montage de mes pneus neufs et un parallélisme. Service ultra rapide, café offert pendant l'attente et explications claires."</p>
        </div>
        <div class="review-card">
          <div class="review-header">
            <div class="review-author">
              <div class="author-avatar">N</div>
              <div class="author-info"><h4>Nicolas Dubois</h4><span>Il y a 2 mois</span></div>
            </div>
            <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google" class="google-g" width="18" height="18" loading="lazy" />
          </div>
          <div class="review-stars">★ ★ ★ ★ ★</div>
          <p class="review-content">"Rénovation complète de ma carrosserie latérale suite à un frottement. Travail impeccable, la peinture est identique à celle d'origine."</p>
        </div>
      </div>
      <div class="reviews-summary">
        <div class="summary-google">
          <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google" width="40" height="40" loading="lazy" />
          <div>
            <div class="summary-score">4.5 / 5</div>
            <p style="margin:0;">Évalué par nos clients</p>
          </div>
        </div>
        <div class="summary-stars">
          <div class="stars">★ ★ ★ ★ ★</div>
          <p style="margin:0; font-size:0.85rem; color:var(--gris);">Sur la base de plus de 500 avis</p>
        </div>
        <a href="https://search.google.com/local/reviews?placeid=ChIJ31300_CarRepairToulouse" target="_blank" rel="noopener noreferrer" class="btn btn-outline" style="padding: 0.7rem 1.5rem; font-size: 0.9rem;">Laisser un avis Google</a>
      </div>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container cta-container reveal-on-scroll">
      <h2 class="cta-title">Votre voiture a besoin d'une intervention ?</h2>
      <p class="cta-desc">N'attendez pas qu'une petite panne s'aggrave. Demandez dès maintenant votre devis gratuit ou prenez rendez-vous par téléphone.</p>
      <div class="cta-actions">
        <a href="tel:0562837429" class="phone-big">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          05 62 83 74 29
        </a>
        <a href="/contact.html" class="btn btn-primary">Prendre RDV en ligne</a>
      </div>
    </div>
  </section>
</BaseLayout>
