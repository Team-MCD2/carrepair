---
import logoImg from '../assets/logo.png';

interface Props {
  active?: 'index' | 'prestations' | 'a-propos' | 'contact';
}

const { active } = Astro.props;

const links = [
  { id: 'index', href: '/', label: 'Accueil' },
  { id: 'prestations', href: '/prestations/', label: 'Prestations' },
  { id: 'a-propos', href: '/a-propos/', label: 'À Propos' },
  { id: 'contact', href: '/contact/', label: 'Contact' },
] as const;
---

<header id="site-header">
  <div class="container header-container">
    <a href="/" class="logo-wrapper">
      <img src={logoImg.src} alt="Car Repair Toulouse" class="logo-img" width="48" height="48" loading="eager" decoding="async" />
      <div class="logo-text">Car<span>Repair</span></div>
    </a>
    <nav>
      <ul class="nav-links">
        {links.map((link) => (
          <li>
            <a href={link.href} class:list={['nav-link', { active: active === link.id }]}>{link.label}</a>
          </li>
        ))}
      </ul>
      <button class="menu-toggle" aria-label="Menu de navigation" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </nav>
    <a href="/contact/" class="btn-header">Demander un Devis</a>
  </div>
</header>

