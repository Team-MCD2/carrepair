---
interface Props {
  videoId: string;
  title?: string;
  class?: string;
  cover?: boolean;
}

const { videoId, title = 'Vidéo', class: className = '', cover = false } = Astro.props;
---

<div
  class:list={['yt-loop', className, { 'yt-loop--cover': cover }]}
  data-yt-loop
  data-yt-id={videoId}
  data-yt-max="30"
>
  <div class="yt-loop-player" aria-label={title}></div>
  <div class="yt-loop-vignette" aria-hidden="true"></div>
  <div class="yt-loop-shield" aria-hidden="true"></div>
</div>
