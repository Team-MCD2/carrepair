---
interface Props {
  src: string;
  poster: string;
  tag: string;
  title: string;
  delay?: number;
}

const { src, poster, tag, title, delay = 0 } = Astro.props;
---

<article class="video-card reveal-on-scroll" data-delay={delay}>
  <video class="video-card-player" muted loop playsinline preload="none" poster={poster} data-lazy-video>
    <source src={src} type="video/mp4" />
  </video>
  <div class="video-card-overlay">
    <span class="video-card-tag">{tag}</span>
    <h3>{title}</h3>
  </div>
</article>
