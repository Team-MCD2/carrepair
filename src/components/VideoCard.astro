---
import LocalVideo from './LocalVideo.astro';

interface Props {
  src: string;
  poster: string;
  tag: string;
  title: string;
  delay?: number;
}

const { src, poster, tag, title, delay = 0 } = Astro.props;
---

<article class="video-card reveal-on-scroll" data-delay={delay}>
  <LocalVideo src={src} poster={poster} cover={true} />
  <div class="video-card-overlay">
    <span class="video-card-tag">{tag}</span>
    <h3>{title}</h3>
  </div>
</article>
