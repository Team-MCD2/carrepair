---
interface Props {
  src: string;
  poster?: string;
  class?: string;
  cover?: boolean;
  eager?: boolean;
}

const {
  src,
  poster,
  class: className = '',
  cover = false,
  eager = false,
} = Astro.props;

const videoClass = ['bg-video', className, cover ? 'bg-video--cover' : ''].filter(Boolean).join(' ');
---

<video
  class={videoClass}
  muted
  loop
  playsinline
  disablepictureinpicture
  disableremoteplayback
  poster={poster}
  preload={eager ? 'auto' : 'none'}
  data-bg-video
  {...(!eager ? { 'data-lazy': '' } : {})}
>
  {eager ? (
    <source src={src} type="video/mp4" />
  ) : (
    <source data-src={src} type="video/mp4" />
  )}
</video>
