---
import YouTubeLoop from './YouTubeLoop.astro';
import { YOUTUBE, POSTERS } from '../data/videos';

interface Props {
  videoId?: string;
  posterSrc?: string;
}

const { videoId = YOUTUBE.hero, posterSrc = POSTERS.hero } = Astro.props;
---

<section class="hero hero--video hero--cinematic">
  <div class="hero-media" aria-hidden="true">
    <img
      src={posterSrc}
      alt=""
      class="hero-poster"
      width="1920"
      height="1080"
      fetchpriority="high"
      decoding="async"
    />
    <YouTubeLoop videoId={videoId} cover={true} class="hero-yt" />
  </div>
  <div class="container">
    <div class="hero-content">
      <slot />
    </div>
  </div>
</section>

